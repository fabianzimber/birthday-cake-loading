{
  "name": "@birthday-cake-loading/react",
  "version": "0.2.0",
  "description": "React bindings for birthday-cake-loading (provider, gating components, devtools).",
  "keywords": [
    "progressive-enhancement",
    "performance",
    "react",
    "accessibility",
    "bcl"
  ],
  "homepage": "https://github.com/shiftbloom-studio/birthday-cake-loading#readme",
  "bugs": {
    "url": "https://github.com/shiftbloom-studio/birthday-cake-loading/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiftbloom-studio/birthday-cake-loading.git"
  },
  "license": "GPL-3.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./upgrade": {
      "types": "./dist/upgrade.d.ts",
      "import": "./dist/upgrade.js",
      "require": "./dist/upgrade.cjs"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.js",
      "require": "./dist/devtools.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@birthday-cake-loading/core": "0.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}

