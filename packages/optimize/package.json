{
  "name": "@birthday-cake-loading/optimize",
  "version": "0.2.0",
  "description": "Tier-aware wrappers and optional build-time helpers for performance-heavy libraries in birthday-cake-loading.",
  "keywords": [
    "progressive-enhancement",
    "performance",
    "bcl"
  ],
  "homepage": "https://github.com/shiftbloom-studio/birthday-cake-loading#readme",
  "bugs": {
    "url": "https://github.com/shiftbloom-studio/birthday-cake-loading/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiftbloom-studio/birthday-cake-loading.git"
  },
  "license": "GPL-3.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./framer-motion": {
      "types": "./dist/framer-motion.d.ts",
      "import": "./dist/framer-motion.js",
      "require": "./dist/framer-motion.cjs"
    },
    "./gsap": {
      "types": "./dist/gsap.d.ts",
      "import": "./dist/gsap.js",
      "require": "./dist/gsap.cjs"
    },
    "./three": {
      "types": "./dist/three.d.ts",
      "import": "./dist/three.js",
      "require": "./dist/three.cjs"
    },
    "./swiper": {
      "types": "./dist/swiper.d.ts",
      "import": "./dist/swiper.js",
      "require": "./dist/swiper.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "framer-motion": {
      "optional": true
    },
    "gsap": {
      "optional": true
    },
    "three": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    },
    "swiper": {
      "optional": true
    }
  },
  "dependencies": {
    "@birthday-cake-loading/react": "0.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.21",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vite": "^6.0.0"
  }
}

