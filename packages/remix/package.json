{
  "name": "@birthday-cake-loading/remix",
  "version": "0.2.0",
  "description": "Remix adapter for birthday-cake-loading (server bootstrap + Client Hints helpers).",
  "keywords": [
    "remix",
    "react",
    "progressive-enhancement",
    "performance",
    "bcl"
  ],
  "homepage": "https://github.com/shiftbloom-studio/birthday-cake-loading#readme",
  "bugs": {
    "url": "https://github.com/shiftbloom-studio/birthday-cake-loading/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiftbloom-studio/birthday-cake-loading.git"
  },
  "license": "GPL-3.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "@remix-run/node": ">=1",
    "@remix-run/react": ">=1",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@birthday-cake-loading/core": "0.2.0"
  },
  "devDependencies": {
    "@remix-run/node": "^2.17.2",
    "@remix-run/react": "^2.17.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}

