{
  "name": "@birthday-cake-loading/sveltekit",
  "version": "0.2.0",
  "description": "SvelteKit adapter for birthday-cake-loading (Provider, layers, SSR bootstrap helpers).",
  "keywords": [
    "svelte",
    "sveltekit",
    "progressive-enhancement",
    "performance",
    "bcl"
  ],
  "homepage": "https://github.com/shiftbloom-studio/birthday-cake-loading#readme",
  "bugs": {
    "url": "https://github.com/shiftbloom-studio/birthday-cake-loading/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiftbloom-studio/birthday-cake-loading.git"
  },
  "license": "GPL-3.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "@sveltejs/kit": ">=1",
    "svelte": ">=4"
  },
  "dependencies": {
    "@birthday-cake-loading/core": "0.2.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "svelte": "^5.46.1",
    "svelte-preprocess": "^6.0.3",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "svelte-package"
  }
}

