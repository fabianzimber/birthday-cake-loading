{
  "name": "birthday-cake-loading",
  "version": "0.2.0",
  "description": "Capability-based progressive enhancement for React and Next.js marketing experiences.",
  "keywords": [
    "progressive-enhancement",
    "performance",
    "react",
    "nextjs",
    "accessibility",
    "bcl"
  ],
  "homepage": "https://github.com/shiftbloom-studio/birthday-cake-loading#readme",
  "bugs": {
    "url": "https://github.com/shiftbloom-studio/birthday-cake-loading/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiftbloom-studio/birthday-cake-loading.git"
  },
  "license": "GPL-3.0",
  "author": "",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./upgrade": {
      "types": "./dist/upgrade.d.ts",
      "import": "./dist/upgrade.js",
      "require": "./dist/upgrade.cjs"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.js",
      "require": "./dist/devtools.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "dependencies": {
    "@birthday-cake-loading/core": "0.2.0",
    "@birthday-cake-loading/react": "0.2.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "tsup --watch",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "test": "jest",
    "test:ci": "jest --ci",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@angular/animations": "^21.0.6",
    "@angular/common": "^21.0.6",
    "@angular/core": "^21.0.6",
    "@angular/platform-browser": "^21.0.6",
    "@angular/platform-server": "^21.0.6",
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/cli": "^2.29.8",
    "@remix-run/dev": "^2.17.2",
    "@remix-run/node": "^2.17.2",
    "@remix-run/react": "^2.17.2",
    "@sveltejs/kit": "^2.49.2",
    "@sveltejs/package": "^2.5.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "astro": "^5.16.6",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "nuxt": "^4.2.2",
    "rxjs": "^7.8.2",
    "svelte": "^5.46.1",
    "svelte-preprocess": "^6.0.3",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vue": "^3.5.26",
    "zone.js": "^0.16.0"
  }
}
